# ===========================
# TN CONNECT - Backend Config
# ===========================

# Server
NODE_ENV=development
PORT=5000

# PostgreSQL Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tn_connect_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMS (e.g., Twilio / Africa's Talking)
SMS_PROVIDER=africas_talking
SMS_API_KEY=your_sms_api_key_here
SMS_USERNAME=your_sms_username_here
SMS_SENDER_ID=TNCONNECT

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM="TN Connect <noreply@tnconnect.com>"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
